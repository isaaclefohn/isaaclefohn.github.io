{
  "expo": {
    "name": "Color Block Blast",
    "slug": "color-block-blast",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "newArchEnabled": false,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#1a1a2e"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.isaaclefohn.colorblockblast",
      "buildNumber": "1"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#1a1a2e"
      },
      "package": "com.isaaclefohn.colorblockblast"
    },
    "plugins": [
      [
        "react-native-google-mobile-ads",
        {
          "androidAppId": "ca-app-pub-9923892524770034~9844822777",
          "iosAppId": "ca-app-pub-9923892524770034~9844822777",
          "userTrackingPermission": "This identifier will be used to deliver personalized ads to you."
        }
      ],
      "@sentry/react-native/expo",
      "react-native-iap",
      [
        "expo-notifications",
        {
          "icon": "./assets/icon.png",
          "color": "#1a1a2e"
        }
      ]
    ]
  }
}
